# ============================================================
# CYBER SHATS — Muhit o'zgaruvchilari namunasi
# Bu faylni .env nomi bilan nusxalang va qiymatlarni o'zgartiring:
#   cp .env.example .env
# ============================================================

# Flask xavfsizlik kaliti (sessiyalar uchun) — production'da albatta
# uzun, tasodifiy qatorga o'zgartiring!
SECRET_KEY=cyber-shats-dev-secret-key-CHANGE-ME

# SQLite baza fayli joylashuvi (odatda o'zgartirish shart emas)
DB_PATH=database/cyber_shats.db

# IXTIYORIY: Agar AI Yordamchi bo'limi haqiqiy Claude javoblarini
# bersin desangiz, o'zingizning Anthropic API kalitingizni kiriting.
# Kalit yo'q bo'lsa, AI Yordamchi "demo rejim"da statik javoblar bilan
# ishlaydi — interfeys baribir to'liq ishlaydi.
# Kalitni https://console.anthropic.com dan olishingiz mumkin.
ANTHROPIC_API_KEY=

# Saytning domen nomi (sitemap.xml, robots.txt va SEO meta uchun)
SITE_DOMAIN=cyber.shats.uz

# Flask ishga tushirish sozlamalari
FLASK_DEBUG=0
PORT=8080
