# SHATS.KIBER — Muhit o'zgaruvchilari
# Bu faylni .env deb nusxalab, qiymatlarni to'ldiring

# ⚠️ MUHIM: Ishlab chiqarishda bu qiymatlarni o'zgartiring!

# Flask maxfiy kaliti (kamida 32 ta tasodifiy belgi)
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_32_CHARS_MIN

# Superadmin paroli (birinchi ishga tushirishda o'rnatilib qolinadi)
SUPERADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD!@#

# Telegram Bot (sozlash uchun @BotFather dan oling)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_ADMIN_USERNAME=shedow_777

# Anthropic API (PRO AI xizmatlari uchun)
ANTHROPIC_API_KEY=

# CORS — ruxsat berilgan saytlar (vergul bilan ajrating)
ALLOWED_ORIGINS=http://localhost:5000

# Debug rejimi (ishlab chiqarishda false bo'lishi SHART)
FLASK_DEBUG=false
